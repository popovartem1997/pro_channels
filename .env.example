DEBUG=False
SECRET_KEY=change-me-super-secret

# Site
ALLOWED_HOSTS=prochannels.ru,www.prochannels.ru
SITE_URL=https://prochannels.ru
SITE_NAME=ProChannels

# DB (MySQL in docker)
USE_MYSQL=True
DB_NAME=pro_channels
DB_USER=pro_channels
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=3306
# Пул соединений на воркер (сек). 0 — без пула. Если >0, обязательно CONN_HEALTH_CHECKS в settings (уже включён),
# иначе после MySQL wait_timeout — OperationalError 2006 «Server has gone away».
# DB_CONN_MAX_AGE=300

# MySQL root password (used only by docker container healthcheck/initialization)
DB_ROOT_PASSWORD=change-me-root-password

# Celery / Redis
# В Docker Compose имя хоста сервиса — redis (см. docker-compose environment; 127.0.0.1 внутри контейнера ≠ Redis).
CELERY_BROKER_URL=redis://redis:6379/0
# Опционально; если пусто — берётся из CELERY_BROKER_URL с DB=2
# DJANGO_CACHE_REDIS_URL=redis://redis:6379/2
# В проде в Docker всегда false (в compose переопределено). True = задачи не в Redis, воркер пустой.
CELERY_TASK_ALWAYS_EAGER=False
# True — апдейты Telegram только в Celery (нужен воркер). False — обработка в вебхуке (бот не «молчит» без воркера).
# TELEGRAM_WEBHOOK_USE_CELERY=False
# CELERY_WORKER_PREFETCH_MULTIPLIER=1
# Периодический парсинг: один раз после деплоя — docker compose exec web python manage.py setup_periodic_tasks
# Воркер Celery: import_history,prio,celery,parse (импорт TG→MAX; публикация; прочее; парсинг ленты). См. docker-compose.
# Если воркер без очереди import_history, а импорт «висит» на шаге 0: CELERY_IMPORT_HISTORY_QUEUE=prio (и -Q с prio).
# CELERY_IMPORT_HISTORY_QUEUE=import_history
# Пост «Публикуется» без завершения задачи: повторная постановка раз в минуту после N минут без обновления (по умолчанию 15).
# STUCK_PUBLISHING_RECOVER_MINUTES=15

# Encryption key for tokens (must be stable!)
BOTS_ENCRYPTION_KEY=change-me-fernet-key

# Optional integrations (AI рерайт — DeepSeek API)
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
AI_REWRITE_ENABLED=False

TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=

VK_ORD_ACCESS_TOKEN=
VK_ORD_CABINET_ID=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# За один запуск парсинга Telegram: сколько последних сообщений канала проверять (5–500). По умолчанию 20.
# PARSE_TELEGRAM_MESSAGE_LIMIT=20
# Макс. размер одного документа при скачивании в парсинге (байты). 0 — без лимита. По умолчанию 52428800 (50 MiB).
# PARSE_TELEGRAM_MEDIA_MAX_BYTES=52428800
# Суммарный лимит parsed_items + imports/tg_to_max (байт). 0 — только очистка по дням. По умолчанию 5368709120 (5 GiB).
# PARSE_MEDIA_DISK_QUOTA_BYTES=5368709120
# PARSE_MEDIA_DISK_QUOTA_BYTES=0
VK_PARSE_ACCESS_TOKEN=
