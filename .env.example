DEBUG=False
SECRET_KEY=change-me-super-secret

# Site
ALLOWED_HOSTS=prochannels.ru,www.prochannels.ru
SITE_URL=https://prochannels.ru
SITE_NAME=ProChannels

# DB (MySQL in docker)
USE_MYSQL=True
DB_NAME=pro_channels
DB_USER=pro_channels
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=3306

# MySQL root password (used only by docker container healthcheck/initialization)
DB_ROOT_PASSWORD=change-me-root-password

# Celery / Redis
# В Docker Compose имя хоста сервиса — redis (см. docker-compose environment; 127.0.0.1 внутри контейнера ≠ Redis).
CELERY_BROKER_URL=redis://redis:6379/0
# Опционально; если пусто — берётся из CELERY_BROKER_URL с DB=2
# DJANGO_CACHE_REDIS_URL=redis://redis:6379/2
# В проде в Docker всегда false (в compose переопределено). True = задачи не в Redis, воркер пустой.
CELERY_TASK_ALWAYS_EAGER=False
# CELERY_WORKER_PREFETCH_MULTIPLIER=1
# Периодический парсинг: один раз после деплоя — docker compose exec web python manage.py setup_periodic_tasks
# Воркер Celery: очередь imports должна быть в списке (см. docker-compose), иначе импорт TG→MAX зависнет в pending.

# Encryption key for tokens (must be stable!)
BOTS_ENCRYPTION_KEY=change-me-fernet-key

# Optional integrations (AI рерайт — DeepSeek API)
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
AI_REWRITE_ENABLED=False

TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=

VK_ORD_ACCESS_TOKEN=
VK_ORD_CABINET_ID=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# За один запуск парсинга Telegram: сколько последних сообщений канала проверять (5–500).
# PARSE_TELEGRAM_MESSAGE_LIMIT=80
VK_PARSE_ACCESS_TOKEN=
