#!/usr/bin/env bash
# Коммит и push текущей ветки. Запуск из корня репозитория:
#   ./scripts/push "Краткое описание изменений"
# Несколько слов без кавычек тоже сойдут за одно сообщение:
#   ./scripts/push поправил импорт медиа

set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Ошибка: не git-репозиторий (ожидался корень проекта)." >&2
  exit 1
fi

MSG="${*:-}"
if [[ -z "$MSG" ]]; then
  echo "Использование: ./scripts/push \"Сообщение коммита\"" >&2
  echo "Пример:        ./scripts/push \"Нормализация порядка медиа в посте\"" >&2
  exit 1
fi

git add -A
if git diff --cached --quiet; then
  echo "Нет изменений для коммита — нечего пушить."
  exit 0
fi

git commit -m "$MSG"
BRANCH="$(git branch --show-current)"
git push -u origin "$BRANCH"

echo "Готово: запушено в origin/$BRANCH"
